<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hello.mapper.OrderMapper">
    <!--全部字段-->
    <sql id="Tb_List" > id , order_id , seller_id , buyer_id</sql>

    <!--新增-->
    <insert id="in">
        insert into tb_order(order_id,seller_id,buyer_id) values(#{i},1,1)
    </insert>

    <!--查询-->
    <select id="getId" resultType= "com.hello.pojo.Order">
        select
        <include refid="Tb_List"/>
        from tb_order where ORDER_ID = #{i}
    </select>



</mapper>
